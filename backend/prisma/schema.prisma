generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Machine {
  id          String       @id @default(uuid())
  name        String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  productions Production[]

  @@map("machines")
}

model BrickType {
  id                 String             @id @default(uuid())
  size               String             @unique
  stock              Int                @default(0)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  orderBrickTypes    ClientOrder[]      @relation("OrderBrickType")
  scheduleBrickTypes DispatchSchedule[] @relation("ScheduleBrickType")
  dispatches         Dispatch[]
  productions        Production[]

  @@map("brick_types")
}

model Worker {
  id                 String              @id @default(uuid())
  name               String
  role               String
  paymentType        String
  rate               Float
  isActive           Boolean             @default(true)
  advanceBalance     Float               @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  attendance         Attendance[]
  wages              DailyWage[]
  dispatchSchedules  DispatchSchedule[]
  expenses           Expense[]
  monthlySettlements MonthlySettlement[]
  productionWorkers  ProductionWorker[]
  settlements        WeeklySettlement[]
  advances           WorkerAdvance[]
  cashEntries        CashEntry[]

  @@map("workers")
}

model Production {
  id          String             @id @default(uuid())
  date        DateTime
  machineId   String
  shift       String
  brickTypeId String
  quantity        Int
  damagedBricks   Int                @default(0)
  availableBricks Int                @default(0)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workers     ProductionWorker[] @relation("ProductionToWorkers")
  brickType   BrickType          @relation(fields: [brickTypeId], references: [id])
  machine     Machine            @relation(fields: [machineId], references: [id])

  @@map("productions")
}

model ProductionWorker {
  id           String     @id @default(uuid())
  productionId String
  workerId     String
  quantity     Int
  createdAt    DateTime   @default(now())
  production   Production @relation("ProductionToWorkers", fields: [productionId], references: [id])
  worker       Worker     @relation(fields: [workerId], references: [id])

  @@map("production_workers")
}

model Customer {
  id                String             @id @default(uuid())
  name              String
  phone             String?
  address           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isActive          Boolean            @default(true)
  notes             String?
  orders            ClientOrder[]
  payments          ClientPayment[]
  dispatchSchedules DispatchSchedule[]
  dispatches        Dispatch[]
  cashEntries       CashEntry[]

  @@map("customers")
}

model ClientOrder {
  id                   String          @id @default(uuid())
  clientId             String
  brickTypeId          String
  quantity             Int
  rate                 Float           @default(0)
  totalAmount          Float           @default(0)
  orderDate            DateTime
  expectedDispatchDate DateTime?
  status               String          @default("PENDING")
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  brickType            BrickType       @relation("OrderBrickType", fields: [brickTypeId], references: [id])
  client               Customer        @relation(fields: [clientId], references: [id])
  payments             ClientPayment[]

  @@map("client_orders")
}

model ClientPayment {
  id            String       @id @default(uuid())
  clientId      String
  orderId       String?
  type          String       @default("PAYMENT")
  amount        Float
  paymentDate   DateTime
  paymentMethod String
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  client        Customer     @relation(fields: [clientId], references: [id])
  order         ClientOrder? @relation(fields: [orderId], references: [id])

  @@map("client_payments")
}

model DispatchSchedule {
  id           String    @id @default(uuid())
  clientId     String
  brickTypeId  String
  quantity     Int
  location     String?
  dispatchDate DateTime
  driverId     String?
  status       String    @default("SCHEDULED")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  brickType    BrickType @relation("ScheduleBrickType", fields: [brickTypeId], references: [id])
  client       Customer  @relation(fields: [clientId], references: [id])
  driver       Worker?   @relation(fields: [driverId], references: [id])

  @@map("dispatch_schedules")
}

model Dispatch {
  id            String    @id @default(uuid())
  date          DateTime
  customerId    String
  brickTypeId   String
  quantity      Int
  distanceKm    Float?
  vehicleType   String
  transportCost Float
  loadingCost   Float
  paymentStatus String
  totalAmount   Float
  paidAmount    Float
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  brickType     BrickType @relation(fields: [brickTypeId], references: [id])
  customer      Customer  @relation(fields: [customerId], references: [id])

  @@map("dispatches")
}

model Expense {
  id          String          @id @default(uuid())
  date        DateTime
  category    String
  amount      Float
  notes       String?
  paymentMode String
  workerId    String?
  materialId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  material    RawMaterial?    @relation(fields: [materialId], references: [id])
  worker      Worker?         @relation(fields: [workerId], references: [id])
  materials   MaterialUsage[]

  @@map("expenses")
}

model CashEntry {
  id          String   @id @default(uuid())
  date        DateTime
  type        String
  amount      Float
  description String
  category    String
  paymentMode String   @default("CASH")
  customerId  String?
  workerId    String?
  materialId  String?
  isRecordOnly Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer? @relation(fields: [customerId], references: [id])
  worker      Worker?   @relation(fields: [workerId], references: [id])
  material    RawMaterial? @relation(fields: [materialId], references: [id])

  @@map("cash_entries")
}

model RawMaterial {
  id          String          @id @default(uuid())
  name        String          @unique
  unit        String
  description String?
  stock       Float           @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  expenses    Expense[]
  cashEntries CashEntry[]
  usages      MaterialUsage[]

  @@map("raw_materials")
}

model MaterialUsage {
  id           String      @id @default(uuid())
  materialId   String
  quantity     Float
  pricePerUnit Float       @default(0)
  totalCost    Float       @default(0)
  date         DateTime
  expenseId    String?
  createdAt    DateTime    @default(now())
  expense      Expense?    @relation(fields: [expenseId], references: [id])
  material     RawMaterial @relation(fields: [materialId], references: [id])

  @@map("material_usages")
}

model Attendance {
  id       String   @id @default(uuid())
  workerId String
  date     DateTime
  present  Boolean  @default(true)
  worker   Worker   @relation(fields: [workerId], references: [id])

  @@unique([workerId, date])
  @@map("attendance")
}

model WorkerAdvance {
  id       String   @id @default(uuid())
  workerId String
  amount   Float
  type     String
  date     DateTime
  note     String?
  worker   Worker   @relation(fields: [workerId], references: [id])

  @@map("worker_advances")
}

model DailyWage {
  id          String   @id @default(uuid())
  workerId    String
  date        DateTime
  bricksMade  Int?
  wageAmount  Float
  advanceUsed Float    @default(0)
  netPayable  Float
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
  worker      Worker   @relation(fields: [workerId], references: [id])

  @@map("daily_wages")
}

model WeeklySettlement {
  id            String   @id @default(uuid())
  workerId      String
  startDate     DateTime
  endDate       DateTime
  totalAmount   Float
  paymentStatus String
  generatedAt   DateTime @default(now())
  notes         String?
  worker        Worker   @relation(fields: [workerId], references: [id])

  @@map("weekly_settlements")
}

model MonthlySettlement {
  id          String    @id @default(uuid())
  workerId    String
  month       Int
  year        Int
  salary      Float
  advanceUsed Float     @default(0)
  netPaid     Float
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  worker      Worker    @relation(fields: [workerId], references: [id])

  @@unique([workerId, month, year])
  @@map("monthly_settlements")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
